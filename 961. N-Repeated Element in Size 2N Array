//961. N-Repeated Element in Size 2N Array
class Solution {
public:
    int repeatedNTimes(vector<int>& nums) {
        sort(nums.begin(), nums.end());
        int n = nums.size();
        int m = n / 2;
        int i, count = 1;
        for (i = 1; i < n; i++) {
            if (nums[i-1] == nums[i]) {
                count++;
                if (count == m)
                    return nums[i];
            }else
            count=1;
        }return 0;
    }
};

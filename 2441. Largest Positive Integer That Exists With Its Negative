//2441. Largest Positive Integer That Exists With Its Negative
class Solution {
    public int findMaxK(int[] nums) {
        Arrays.sort(nums);
        int i = 0;
        int j = nums.length - 1;
        while (i != nums.length - 1) {

            while (i < j) {
                if (nums[i] == -1 * (nums[j])) {
                    return Math.abs(nums[j]);
                } else
                    j--;
            }
            i++;
            j = nums.length - 1;
        }
        return -1;
    }
}

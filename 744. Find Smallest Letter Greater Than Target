//744. Find Smallest Letter Greater Than Target
class Solution {
public:
    char nextGreatestLetter(vector<char>& letters, char target) {
        int i;
        sort(letters.begin(), letters.end());
        for (i = 0; i < letters.size(); i++) {
            if (int(letters[i]) > int(target))
                return letters[i];
        }
        return letters[0];
    }
};

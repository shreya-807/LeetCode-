//2643. Row With Maximum Ones
class Solution {
    public int[] rowAndMaximumOnes(int[][] mat) {
        int count = 0;
        int[] res = new int[2];
        int rn = 0;
        int max = 0;
        for (int i = 0; i < mat.length; i++) {
            for (int j = 0; j < mat[i].length; j++) {
                if (mat[i][j] == 1)
                    count++;
            }
            
            if (count > max) {   
                max = count;
                rn = i;
            }
            count = 0;
        }
        res[0] = rn;
        res[1] = max;
        return res;

    }
}

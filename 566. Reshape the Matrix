///566. Reshape the Matrix
class Solution {
public:
    vector<vector<int>> matrixReshape(vector<vector<int>>& mat, int r, int c) {
        vector<int> res;
        int m = mat.size();
        int n = mat[0].size();
        if (r * c != m * n)
            return mat;
        for (int i = 0; i < mat.size(); i++) {
            for (int j = 0; j < mat[i].size(); j++) {
                res.push_back(mat[i][j]);
            }
        }
        int k = 0;

        vector<vector<int>> ans;
        for (int i = 0; i < r; i++) {
            vector<int> row;
            for (int j = 0; j < c; j++) {
                row.push_back(res[k]);
                k++;
            }
            ans.push_back(row);
        }
        return ans;
    }
};

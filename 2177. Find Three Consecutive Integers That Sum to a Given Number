//2177. Find Three Consecutive Integers That Sum to a Given Number
class Solution {
    public long[] sumOfThree(long num) {
        
        ArrayList<Long> res = new ArrayList<>();

       
        if (num % 3 == 0) {
            long a = num / 3 - 1;
            long b = num / 3;
            long c = num / 3 + 1;

          
            res.add(a);
            res.add(b);
            res.add(c);
        }

       
        long[] ans = new long[res.size()];
        for (int i = 0; i < res.size(); i++) {
            ans[i] = res.get(i);
        }

        return ans;
    }
}

//3115. Maximum Prime Difference
class Solution {
    public int maximumPrimeDifference(int[] nums) {
        int ind1 = 0;
        int ind2 = 0;

        for (int i = 0; i < nums.length; i++) {
            int n = nums[i];
            int count = 0;
            int j = 2;
            while (j < n) {
                if (n % j == 0) {
                    count++;
                    break;
                }
                j++;
            }
            if (count == 0 && n > 1) {
                ind1 = i;
                break;

            }

        }

        for (int i = nums.length - 1; i > 0; i--) {
            int n = nums[i];
            int count = 0;
            int j = 2;
            while (j < n) {
                if (n % j == 0) {
                    count++;
                    break;
                }
                j++;
            }
            if (count == 0 && n > 1) {
                ind2 = i;
                break;

            }

        }
        return Math.abs(ind2 - ind1);
    }
}

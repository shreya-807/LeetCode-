//2833. Furthest Point From Origin
class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int left = 0;
        int right = 0;
        int dash = 0;
        for (int i = 0; i < moves.length(); i++) {
            if (moves.charAt(i) == 'L')
                left++;
            else if (moves.charAt(i) == '_')
                dash++;
            else
                right++;
        }
        return Math.abs(left - right)+dash;
    }
}

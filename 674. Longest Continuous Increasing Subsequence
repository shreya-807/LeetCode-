//674. Longest Continuous Increasing Subsequence
class Solution {
    public int findLengthOfLCIS(int[] nums) {
        int count = 1;
        int i=0;
        int ans = 0;
        if (nums.length == 1)
            return 1;
        while(i<nums.length-1) {
            if (nums[i] < nums[i + 1]) {
                count++;
                i++;
            } else {
                count = 1;
                i++;
            }
            ans = Math.max(ans, count);
        }
        return ans;
    }
}

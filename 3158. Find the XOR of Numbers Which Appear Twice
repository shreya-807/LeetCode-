//3158. Find the XOR of Numbers Which Appear Twice
class Solution {
public:
    int duplicateNumbersXOR(vector<int>& nums) {
        int count = 1;
        vector<int> res;
        sort(nums.begin(), nums.end());
        for (int i = 0; i < nums.size() - 1; i++) {
            count = 1;
            if (nums[i] == nums[i + 1])
                count++;
            if (count == 2) {
                res.push_back(nums[i]);
            }
        }
        int ans = 0;
        for (int i = 0; i < res.size(); i++) {
            ans = ans ^ res[i];
        }
        return ans;
    }
};

//3194. Minimum Average of Smallest and Largest Elements
class Solution {
    public double minimumAverage(int[] nums) {
        Arrays.sort(nums);
        ArrayList<Float> res = new ArrayList<>();
        int i = 0;
        int j = nums.length-1;
        while (i < j) {
            res.add((nums[i] + nums[j]) / 2.0f);
            i++;
            j--;
        }
        Collections.sort(res);
        return res.get(0);
    }
}

11. Container With Most Water

class Solution {
    public int maxArea(int[] height) {
        int start = 0;
        int end = height.length - 1;
        int ans = 0;

        while (start < end) {
            int width = end - start;
            int minHeight = Math.min(height[start], height[end]);
            ans = Math.max(ans, minHeight * width);

            
            if (height[start] < height[end]) {
                start++;
            } else {
                end--;
            }
        }
        return ans;
    }
}

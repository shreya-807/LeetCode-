//1848. Minimum Distance to the Target Element
class Solution {
    public int getMinDistance(int[] nums, int target, int start) {
        int ans = 10000;
        for (int i = 0; i < nums.length; i++) {
            if (nums[i] == target) {
                ans = Math.min(ans, Math.abs(i - start));
            }
        }
        return ans;
    }
}
